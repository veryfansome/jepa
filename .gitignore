.claude/settings.local.json

terminal-jepa/.venv/
**/__pycache__/
*.pyc

terminal-jepa/data/*/*.jsonl
terminal-jepa/runs/**/ckpt*.pt
terminal-jepa/runs/**/*.pt
terminal-jepa/data/**/emb-*.pt

# experiment stdout logs + scratch (noise, regenerable) — result JSONs stay tracked
terminal-jepa/runs/**/*.log
terminal-jepa/runs/**/*.out
terminal-jepa/**/scratchpad/
# regenerable perf cache; the genomes.jsonl archive stays tracked (the real record)
terminal-jepa/evolve/archive/base_cache.json
terminal-jepa/runs/dockerfs/seq-smoke-s0.json
# old Phase-1 (synthetic) reproduction scratch — regenerable
terminal-jepa/runs/repro/

# cloud offload runtime state (scripts are tracked; results/state/jobs are per-round scratch)
terminal-jepa/cloud/podresults/
terminal-jepa/cloud/*.state
terminal-jepa/cloud/*.log
terminal-jepa/cloud/jobs.tsv

# plangoals-v1 is a FROZEN EVAL INSTRUMENT (both Phase-0 preregs reference it; image-tag
# drift makes regeneration unfaithful) — exempt from the data/ ignore rules, track it whole
!terminal-jepa/data/plangoals-v1/*.jsonl
# path-battery encode caches (regenerable per root/recipe; repo was history-purged once for size)
terminal-jepa/data/**/pbenc-*.pt
# v3 precompute baseline-arm caches (derived, published to HF; keep them out of git like emb-*.pt)
terminal-jepa/data/**/sst-*.pt
terminal-jepa/data/**/wtm-*.pt
